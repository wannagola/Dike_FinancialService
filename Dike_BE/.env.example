# 앱 기본 설정
APP_NAME=디케
APP_ENV=development  # development | production

# JWT 보안 (랜덤 32자 이상 문자열 사용)
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dike

# Redis
REDIS_URL=redis://localhost:6379/0

# Clova OCR (https://console.ncloud.com/ocr)
CLOVA_OCR_API_URL=https://XXXXXXXX.apigw.ntruss.com/custom/v1/XXXXX/XXXXX/general
CLOVA_OCR_SECRET_KEY=your-clova-secret-key

# OpenAI (GPT-4o mini 문서 분류용)
OPENAI_API_KEY=sk-...

# Cloudflare R2 (문서 이미지 저장)
R2_ENDPOINT_URL=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dike-documents

# 금융결제원 오픈뱅킹
OPENBANKING_CLIENT_ID=your-client-id
OPENBANKING_CLIENT_SECRET=your-client-secret

# FCM 푸시 알림 (서비스 계정 JSON 파일 경로)
FCM_CREDENTIALS_PATH=./firebase-credentials.json
